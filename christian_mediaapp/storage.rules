rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Post media — any authenticated user can upload; public read.
    // Images capped at 10 MB, videos capped at 100 MB.
    // Only image/* and video/* MIME types are allowed.
    match /posts/{postId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && (
          // Image: up to 10 MB
          (request.resource.contentType.matches('image/.*')
            && request.resource.size < 10 * 1024 * 1024)
          ||
          // Video: up to 100 MB
          (request.resource.contentType.matches('video/.*')
            && request.resource.size < 100 * 1024 * 1024)
        );
    }

    // User avatars — owner writes, public reads
    match /avatars/{userId}/{allPaths=**} {
      allow read: if true;
      // Only the owner may write their avatar; limit size to 2 MB.
      allow write: if request.auth != null && request.auth.uid == userId &&
                   request.resource.size < 2 * 1024 * 1024;
    }

    // User banners — owner writes, public reads
    match /banners/{userId}/{allPaths=**} {
      allow read: if true;
      // Only the owner may write their banner; limit size to 5 MB.
      allow write: if request.auth != null && request.auth.uid == userId &&
                   request.resource.size < 5 * 1024 * 1024;
    }
  }
}
